{
  "appId": "com.pvkslabs.listmate",
  "appName": "Listmate",
  "webDir": "static",
  "server": {
    "url": "https://grocerlist.app",
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": [
      "accounts.google.com"
    ]
